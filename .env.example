# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Next.js loads .env automatically in dev and build.
# Never commit .env — it is gitignored.

# -----------------------------------------------------------------------------
# Supabase (required)
# Dashboard → Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — Dashboard → Project Settings → API → service_role
# Enables local registration without confirmation emails (avoids rate limits).
# NEVER expose this key in the browser or commit it to git.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# App URL (required for production invite links & QR codes)
# Local dev: http://localhost:3000
# Production: your deployed origin, e.g. https://collabclass.example.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Logging (optional)
# Levels: debug | info | warn | error
# Dev defaults to debug; production defaults to info.
# Browser logs use NEXT_PUBLIC_LOG_LEVEL; server uses LOG_LEVEL or the same.
# -----------------------------------------------------------------------------
# LOG_LEVEL=debug
# NEXT_PUBLIC_LOG_LEVEL=debug

# After running 004_seed_dev_users.sql — see supabase/SEED_USERS.md
# Officer: officer@trippy-tropa.dev / Officer123!
# Student: student@trippy-tropa.dev / Student123!
